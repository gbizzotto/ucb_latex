% artbitrary placement of text
\newcommand{\placetextbox}[3]{% \placetextbox{<horizontal pos>}{<vertical pos>}{<stuff>}
  \setbox0=\vbox{#3}% Put <stuff> in a box
  \AddToShipoutPictureFG*{% Add <stuff> to current page foreground
    \put(\LenToUnit{#1\paperwidth},\LenToUnit{#2\paperheight}){\vtop{{\null}\makebox[0pt][c]{#3}}}%
  }%
}%

% 1 equation
% 2 addendum on same line (e.g. \cite)
\newcommand{\eq}[2]{
	\begin{spacing}{1.5}
	\begin{raggedright}
    \hspace{.3cm}
    {\large #1\hspace{.3cm}#2}
	\end{raggedright}
	\end{spacing}
}
% 1 equation number
% 2 equation
% 3 addendum on same line (e.g. \cite)
\newcommand{\eqnum}[3]{
	\begin{spacing}{1.5}
	\begin{raggedright}
    {\Large (#1)\hspace{1cm}#2\hspace{1cm}#3}
	\end{raggedright}
	\end{spacing}
}

\newcommand{\result}[1]{
	\begin{spacing}{2}
    \begin{centering}
    \fbox{
	    {\huge #1}
	}
    \par
    \end{centering}
	\end{spacing}
}


\newcommand{\iniciotexto}
{	
	\fancyhead[R]{\thepage}
}

\newcommand{\sumario}
{
	\begin{center}
	\tableofcontents
	\end{center}
	\pagebreak
}

% 1 - Curso
% 2 - Matéria
% 3 - Título
% 4 - Nome do autor
% 5 - Ano de criação (e.g. 2026)
\newcommand{\capa}[5]{
    % Add background image only to this page
    \AddToShipoutPictureBG*{%
        \AtPageLowerLeft{%
            \includegraphics[width=\paperwidth,height=\paperheight]{ucb/images/background.png}%
        }%
    }    
 	\placetextbox{.5}{.82}{
	 	\begin{minipage}{0.8\textwidth}
	 	\centering
		\fontsize{18}{20}\selectfont{\bf{\textcolor{Blue}{{Pró-Reitoria Acadêmica}}}}
		
		\fontsize{18}{20}\selectfont{\bf{\textcolor{Blue}{{#1}}}}
		
		\fontsize{18}{20}\selectfont{\bf{\textcolor{Blue}{{#2}}}}
		\end{minipage}
 	}
 	\placetextbox{.5}{.55}{\fontsize{18}{20}\selectfont{\bf{\textcolor{Blue}{{\uppercase{#3}}}}}}
 	\placetextbox{.5}{.35}{
	 	\begin{minipage}{1.1\textwidth}
		 	\raggedleft
	 		\fontsize{18}{20}\selectfont{\bf{\textcolor{Blue}{{\raggedleft #4}}}}
	 	\end{minipage}
 	}
 	\placetextbox{.5}{.07}{
	 	\begin{minipage}{0.8\textwidth}
	 	\centering
		\fontsize{18}{20}\selectfont{\bf{\textcolor{White}{{Brasília - DF}}}}
		
		\fontsize{18}{20}\selectfont{\bf{\textcolor{White}{{#5}}}}
		\end{minipage}
	}
	% have _something_ on this page so that newpage actually goes to next page
	\mbox{}
	\newpage
}

