%\graphicspath{ {ucb/images} }

\newcommand{\sectiontitle}[1]{
    \begin{center}
    \section{ #1 }
    \end{center}
}

\newcommand{\eq}[1]{

    \vspace{.2cm}
    \hspace{.3cm}
    {\large #1 }
}
\newcommand{\eqnum}[2]{

    \vspace{.2cm}
    (#1)
    \hspace{1cm}
    {\Large #2 }
}

\newcommand{\result}[1]{
    \\
    \centering
    \vspace{.2cm}
    \fbox{
	    {\huge #1}
	    \newline
    }
    \\
    \raggedright
    \vspace{.5cm}
}


\newcommand{\sumario}
{
	\tableofcontents
	\pagebreak
	\renewcommand{\footrulewidth}{0.4pt}
	\fancyfoot[R]{\thepage}
}

% Curso
% Título
% Nome completo do autor
% Ano de criação (e.g. 2026)
\newcommand{\capa}[6]{
	\newgeometry{left=20mm, right=20mm, top=20mm, bottom=8mm}

	%\begin{titlepage}
    % Add background image only to this page
    \AddToShipoutPictureBG*{%
        \AtPageLowerLeft{%
            \includegraphics[width=\paperwidth,height=\paperheight]{ucb/images/background.png}%
        }%
    }


    \centering
    \topskip0pt

    \fontsize{18}{20}\selectfont
    {
    	\bf{
		    \textcolor{Blue}{
		    {
			    \vspace*{\fill}
			    \\
	    		Pró-Reitoria Acadêmica
	    		\\
			    #1
			    \\
			    \vspace*{\fill}
			    \vspace*{\fill}
			    #2
			    \\
			    #3
			    \\
			    \vspace*{\fill}
			    \vspace*{\fill}
			    \raggedleft
			    Autor: #4 (#5)
			    \\
			    \vspace*{\fill}
			    \vspace*{\fill}
			    \vspace*{\fill}
			    \centering 
			    \textcolor{white}{\Large \bf Brasília - DF}
			    \vspace{0.2cm}
			    \\
			}}
		}
	    \textcolor{white}{#6}
	}   
	%\end{titlepage}

	\restoregeometry
	\fontsize{12}{14}\selectfont{}
}

