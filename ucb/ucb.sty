	    {\huge #1}
	    \\
	    \vspace*{\fill}
	    \vspace*{\fill}
	    \vspace*{\fill}
	    \vspace*{\fill}
	    {\Huge Hidraulica}
	    \vspace{0.5cm}
	    \\
	    {\Huge #2}
	    \\
	    \vspace*{\fill}
	    \vspace*{\fill}
	    \vspace*{\fill}
	    \vspace*{\fill}
	    \raggedright
	    {\Huge Autor: #3 (#4)}
	    \\
	    \vspace*{\fill}
	    \centering 
	    \textcolor{white}{\Large \bf Brasília - DF}
	    \vspace{0.2cm}
	    \\
	    \textcolor{white}{\Large \bf #5}
	    
