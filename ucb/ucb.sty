\newcommand{\sectiontitle}[1]{
    \begin{center}
    \section{ #1 }
    \end{center}
}

\newcommand{\eq}[1]{

    \vspace{.2cm}
    \hspace{.3cm}
    {\large #1 }
}
\newcommand{\eqnum}[2]{

    \vspace{.2cm}
    (#1)
    \hspace{1cm}
    {\Large #2 }
}

\newcommand{\result}[1]{
    \\
    \centering
    \vspace{.2cm}
    \fbox{
	    {\huge #1}
	    \newline
    }
    \\
    \raggedright
    \vspace{.5cm}
}


\newcommand{\sumario}
{
	\tableofcontents
	\pagebreak
	\renewcommand{\footrulewidth}{0.4pt}
	\fancyfoot[R]{\thepage}
}

% Curso
% Título
% Nome completo do autor
% Ano de criação (e.g. 2026)
\newcommand{\capa}[5]{
