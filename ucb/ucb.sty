	%\begin{titlepage}
    % Add background image only to this page
    \AddToShipoutPictureBG*{%
        \AtPageLowerLeft{%
            \includegraphics[width=\paperwidth,height=\paperheight]{ucb/images/background.png}%
        }%
    }
    
    \centering
    \topskip0pt

	    \vspace*{\fill}
	    \vspace*{\fill}
	    {\huge Pró-Reitoria Acadêmica}
	    \vspace{0.5cm}
